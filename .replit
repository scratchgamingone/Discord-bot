modules = ["nodejs-16"]
run = "npm run dev"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm run dev"]

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 33051769
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node main.js"
